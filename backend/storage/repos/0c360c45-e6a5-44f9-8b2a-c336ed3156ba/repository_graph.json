        "word_cloud_image"
      ]
    },
    {
      "flow_name": "Document Summarization",
      "description": "User uploads a document and requests a summary, which is generated using a HuggingFace transformer model.",
      "steps": [
        "uploaded_file",
        "app.py",
        "transformers",
        "distilbart-cnn-12-6",
        "summary_output"
      ]
    },
    {
      "flow_name": "Legal Term Explanation",
